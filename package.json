{
  "name": "cloudflare-site-kurulum-otomasyonu",
  "private": true,
  "version": "1.0.22",
  "type": "module",
  "main": "electron/main.mjs",
  "build": {
    "appId": "com.saffetcelik.cloudflare.otomasyon",
    "productName": "Cloudflare Site Kurulum Otomasyonu",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "electron/**/*"
    ],
    "icon": "installer/cloudflare-pages.ico",
    "win": {
      "target": "dir",
      "icon": "installer/cloudflare-pages.ico"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    }
  },
  "scripts": {
    "dev": "tsx server.ts",
    "dev:electron": "npx -y kill-port 3000 && npm run build:electron-main && concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "build:server": "npx esbuild server.ts --bundle --platform=node --format=cjs --outfile=dist-server/server.cjs --external:vite --external:fsevents --define:process.env.NODE_ENV=\"\\\"production\\\"\"",
    "build:electron-main": "npx esbuild electron/main.ts --bundle --platform=node --format=esm --outfile=electron/main.mjs --external:electron --external:module --external:url --external:path --external:fs --external:os --external:crypto --external:http --external:child_process --external:net",
    "build:electron": "npm run build && npm run build:server && npm run build:electron-main && electron-builder",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}