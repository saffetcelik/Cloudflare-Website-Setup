# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CLOUDFLARE_API_TOKEN: Optional - Required for automatic DNS record creation when adding custom domains.
# Without this token, domain will be added to Pages but DNS must be configured manually via Dashboard.
# Create token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone - DNS - Edit, Zone - Zone - Read
CLOUDFLARE_API_TOKEN=""

# AUTH_SERVICE_URL: The URL of your authentication/authorization service.
# This service handles user login via PKCE OAuth flow.
# Default: https://saffetcelik.com.tr
AUTH_SERVICE_URL="https://your-auth-service.com"

# AUTH_TOKEN_FILE: Local file name to store the auth token (in user home directory).
# Default: .saffetcelik-app-token
AUTH_TOKEN_FILE=".your-app-token"

# VITE_AUTH_SERVICE_DOMAIN: Domain name shown in the UI for the auth service.
# Default: saffetcelik.com.tr
VITE_AUTH_SERVICE_DOMAIN="your-auth-service.com"

# TEMPLATE_DOWNLOAD_BASE_URL: Public HTTP URL for downloading site templates.
# When set, templates are downloaded via HTTP (any user can access).
# When empty, falls back to `wrangler r2 object get` (requires R2 bucket ownership).
# Options:
#   - R2 public access: "https://pub-xxxxx.r2.dev"
#   - R2 custom domain: "https://templates.yourdomain.com"
#   - Cloudflare Worker: "https://your-template-worker.yourdomain.com"
TEMPLATE_DOWNLOAD_BASE_URL=""
